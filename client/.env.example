# Copy this file to `.env` and adjust for your environment.
# All client-side Vite env vars must be prefixed with VITE_.

# Base URL of the backend API (without the trailing /api).
VITE_API_URL=http://localhost:7000

# Auth0 SPA configuration. These are public values (no client secret lives in
# the frontend); they identify the Auth0 application the SPA talks to.
VITE_AUTH0_DOMAIN=dev-m3ve8sir.us.auth0.com
VITE_AUTH0_CLIENT_ID=O7WVznRNsyNwwmX0taD3veM6Yj3hEjhc
VITE_AUTH0_AUDIENCE=https://issue-tracker
VITE_AUTH0_SCOPE=openid profile Issue Tracker email
